// Updated untuk mendukung Product_ID system
function updateStokRealOptimized() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const stokSheet = ss.getSheetByName('STOK_REAL');
    const produkSheet = ss.getSheetByName('MASTER_PRODUK');
    const masukSheet = ss.getSheetByName('BARANG_MASUK');
    const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
    
    // Clear existing data
    const lastRow = stokSheet.getLastRow();
    if (lastRow > 2) {
      stokSheet.getRange(3, 1, lastRow - 2, 7).clearContent();
    }
    
    // Cek apakah menggunakan Product_ID system
    const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
    const hasProductID = headers.includes('Product_ID');
    
    // Get product data
    const allProdukData = produkSheet.getDataRange().getValues();
    const produkData = allProdukData.slice(3); // Skip rows 1, 2, 3
    
    const masukData = masukSheet.getDataRange().getValues().slice(2);
    const keluarData = keluarSheet.getDataRange().getValues().slice(2);
    
    const today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd HH:mm:ss');
    
    const stokDataToUpdate = [];
    
    // Process each product
    produkData.forEach(produk => {
      if (!produk[0] || produk[0] === '') return;
      
      let productID, kode, nama, minStok;
      
      if (hasProductID) {
        productID = produk[0]; // Product_ID di kolom A
        kode = produk[1];      // Kode di kolom B
        nama = produk[2];      // Nama di kolom C
        minStok = produk[5] || 10; // Min_Stok di kolom F
      } else {
        kode = produk[0];      // Kode di kolom A (legacy)
        nama = produk[1];      // Nama di kolom B
        minStok = produk[4] || 10; // Min_Stok di kolom E
      }
      
      // Calculate totals - search by both Product_ID and kode for backward compatibility
      let totalMasuk = 0;
      masukData.forEach(row => {
        const refValue = row[3]; // Column D
        if (refValue === (productID || kode) || refValue === kode) {
          totalMasuk += parseInt(row[4]) || 0; // Column E is Qty
        }
      });
      
      let totalKeluar = 0;
      keluarData.forEach(row => {
        const refValue = row[3]; // Column D
        if (refValue === (productID || kode) || refValue === kode) {
          totalKeluar += parseInt(row[4]) || 0; // Column E is Qty
        }
      });
      
      const sisa = totalMasuk - totalKeluar;
      
      stokDataToUpdate.push([kode, nama, totalMasuk, totalKeluar, sisa, minStok, today]);
    });
    
    // Update all data in one operation
    if (stokDataToUpdate.length > 0) {
      const range = stokSheet.getRange(3, 1, stokDataToUpdate.length, 7);
      range.setValues(stokDataToUpdate);
    }
    
    console.log('Stok updated successfully with Product_ID compatibility');
    
  } catch (error) {
    console.error('updateStokRealOptimized error:', error.toString());
  }
}

