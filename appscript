// STEP 2: Sort transaction sheets
function sortTransactionSheets(ss) {
  const masukSheet = ss.getSheetByName('BARANG_MASUK');
  const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
  
  let masukSorted = 0;
  let keluarSorted = 0;
  
  // Sort BARANG_MASUK by date (column A)
  if (masukSheet) {
    const masukRange = masukSheet.getDataRange();
    if (masukRange.getNumRows() > 2) { // Has data beyond header
      const dataRange = masukRange.offset(2, 0, masukRange.getNumRows() - 2); // Skip title and header
      dataRange.sort({column: 1, ascending: true}); // Sort by column A (Tanggal)
      masukSorted = dataRange.getNumRows();
      console.log(`BARANG_MASUK sorted: ${masukSorted} rows`);
    }
  }
  
  // Sort BARANG_KELUAR by date (column A)
  if (keluarSheet) {
    const keluarRange = keluarSheet.getDataRange();
    if (keluarRange.getNumRows() > 2) { // Has data beyond header
      const dataRange = keluarRange.offset(2, 0, keluarRange.getNumRows() - 2); // Skip title and header
      dataRange.sort({column: 1, ascending: true}); // Sort by column A (Tanggal)
      keluarSorted = dataRange.getNumRows();
      console.log(`BARANG_KELUAR sorted: ${keluarSorted} rows`);
    }
  }
  
  return {
    masukSorted: masukSorted,
    keluarSorted: keluarSorted
  };
}

function rebuildKeuanganChronologically(ss) {
  const keuanganSheet = ss.getSheetByName('KEUANGAN');
  const masukSheet = ss.getSheetByName('BARANG_MASUK');
  const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
  const produkSheet = ss.getSheetByName('MASTER_PRODUK');
  
  console.log('Starting keuangan rebuild with strict validation...');
  
  // Backup existing keuangan data
  const existingKeuanganData = keuanganSheet.getDataRange().getValues();
  
  // IMPROVED: Cari SEMUA entry manual dengan validasi yang lebih ketat
  const manualEntries = [];
  existingKeuanganData.slice(2).forEach((row, index) => {
    // Skip baris yang kosong atau tidak valid
    if (!row[0] || !row[1] || !row[2] || !row[3]) {
      console.log(`Skipping invalid row ${index + 3}:`, row);
      return;
    }
    
    const tanggal = row[0];
    const keterangan = row[1] ? row[1].toString().toLowerCase() : '';
    const tipe = row[2];
    const jumlah = row[3];
    
    // Validasi tanggal
    const dateObj = new Date(tanggal);
    if (isNaN(dateObj.getTime()) || dateObj.getFullYear() < 2000) {
      console.log(`Invalid date at row ${index + 3}:`, tanggal);
      return;
    }
    
    // Manual entry = BUKAN dari transaksi barang (tidak mengandung "beli" atau "jual")
    const isBeli = keterangan.includes('beli');
    const isJual = keterangan.includes('jual');
    
    if (!isBeli && !isJual) {
      console.log(`Found manual entry at row ${index + 3}:`, keterangan);
      manualEntries.push({
        rowIndex: index + 3,
        date: dateObj,
        keterangan: row[1],
        tipe: tipe,
        jumlah: jumlah,
        refNo: row[5] || '-'
      });
    }
  });
  
  console.log('Manual entries found:', manualEntries.length);
  
  // Clear keuangan sheet (keep title and header)
  if (keuanganSheet.getLastRow() > 2) {
    keuanganSheet.getRange(3, 1, keuanganSheet.getLastRow() - 2, 6).clearContent();
  }
  
  // Get product mapping
  const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
  const hasProductID = headers.includes('Product_ID');
  const produkData = produkSheet.getDataRange().getValues().slice(3);
  const productMapping = {};
  
  produkData.forEach(row => {
    if (hasProductID && row[0] && row[1]) {
      productMapping[row[0]] = row[1]; // Product_ID -> Kode
      productMapping[row[1]] = row[1]; // Kode -> Kode
    } else if (row[0]) {
      productMapping[row[0]] = row[0]; // Kode -> Kode
    }
  });
  
  // Collect all transactions
  const allTransactions = [];
  
  // Add manual entries back (VALIDATED)
  manualEntries.forEach(entry => {
    if (entry.date && entry.keterangan && entry.tipe && entry.jumlah) {
      allTransactions.push({
        date: entry.date,
        keterangan: entry.keterangan,
        tipe: entry.tipe,
        jumlah: entry.jumlah,
        refNo: entry.refNo,
        type: 'manual'
      });
    }
  });
  
  console.log('Manual transactions added:', manualEntries.length);
  
  // Add barang masuk (DENGAN VALIDASI KETAT)
  const masukData = masukSheet.getDataRange().getValues().slice(2);
  let masukCount = 0;
  
  masukData.forEach((row, index) => {
    // Validasi data
    if (!row[0] || !row[2] || !row[3] || !row[6]) {
      console.log(`Skipping invalid MASUK row ${index + 3}`);
      return;
    }
    
    const tanggal = row[0];
    const supplier = row[2];
    const productRef = row[3];
    const total = row[6];
    
    // Validasi tanggal
    const dateObj = new Date(tanggal);
    if (isNaN(dateObj.getTime()) || dateObj.getFullYear() < 2000) {
      console.log(`Invalid date in MASUK row ${index + 3}:`, tanggal);
      return;
    }
    
    // Validasi amount
    if (typeof total !== 'number' || total <= 0) {
      console.log(`Invalid amount in MASUK row ${index + 3}:`, total);
      return;
    }
    
    const displayCode = productMapping[productRef] || productRef;
    
    allTransactions.push({
      date: dateObj,
      keterangan: `Beli ${displayCode} dari ${supplier}`,
      tipe: 'Keluar',
      jumlah: total,
      refNo: row[1] || '-',
      type: 'masuk'
    });
    
    masukCount++;
  });
  
  console.log('MASUK transactions added:', masukCount);
  
  // Add barang keluar (DENGAN VALIDASI KETAT)
  const keluarData = keluarSheet.getDataRange().getValues().slice(2);
  let keluarCount = 0;
  
  keluarData.forEach((row, index) => {
    // Validasi data
    if (!row[0] || !row[2] || !row[3] || !row[6]) {
      console.log(`Skipping invalid KELUAR row ${index + 3}`);
      return;
    }
    
    const tanggal = row[0];
    const cabang = row[2];
    const productRef = row[3];
    const total = row[6];
    
    // Validasi tanggal
    const dateObj = new Date(tanggal);
    if (isNaN(dateObj.getTime()) || dateObj.getFullYear() < 2000) {
      console.log(`Invalid date in KELUAR row ${index + 3}:`, tanggal);
      return;
    }
    
    // Validasi amount
    if (typeof total !== 'number' || total <= 0) {
      console.log(`Invalid amount in KELUAR row ${index + 3}:`, total);
      return;
    }
    
    const displayCode = productMapping[productRef] || productRef;
    
    allTransactions.push({
      date: dateObj,
      keterangan: `Jual ${displayCode} ke ${cabang}`,
      tipe: 'Masuk',
      jumlah: total,
      refNo: row[1] || '-',
      type: 'keluar'
    });
    
    keluarCount++;
  });
  
  console.log('KELUAR transactions added:', keluarCount);
  console.log('Total transactions to process:', allTransactions.length);
  
  // Sort by date
  allTransactions.sort((a, b) => a.date - b.date);
  
  // Rebuild with running balance
  let currentSaldo = 0;
  let transactionsProcessed = 0;
  
  allTransactions.forEach((transaction, index) => {
    // FINAL VALIDATION sebelum insert
    if (!transaction.date || !transaction.keterangan || !transaction.tipe || !transaction.jumlah) {
      console.log(`Skipping invalid transaction at index ${index}:`, transaction);
      return;
    }
    
    // Validate date sekali lagi
    if (isNaN(transaction.date.getTime()) || transaction.date.getFullYear() < 2000) {
      console.log(`Skipping transaction with invalid date:`, transaction);
      return;
    }
    
    // Calculate balance
    if (transaction.tipe === 'Masuk') {
      currentSaldo += transaction.jumlah;
    } else {
      currentSaldo -= transaction.jumlah;
    }
    
    // Create row dengan validasi
    const keuanganRow = [
      Utilities.formatDate(transaction.date, Session.getScriptTimeZone(), 'yyyy-MM-dd HH:mm:ss'),
      transaction.keterangan,
      transaction.tipe,
      transaction.jumlah,
      currentSaldo,
      transaction.refNo || '-'
    ];
    
    // Final check: pastikan tidak ada undefined
    if (keuanganRow.some(cell => cell === undefined || cell === null)) {
      console.log(`Skipping row with undefined values:`, keuanganRow);
      return;
    }
    
    keuanganSheet.appendRow(keuanganRow);
    
    // Format
    const lastRow = keuanganSheet.getLastRow();
    simpleFormat('KEUANGAN', lastRow);
    
    transactionsProcessed++;
  });
  
  console.log('Keuangan rebuild completed');
  console.log('Transactions processed:', transactionsProcessed);
  console.log('Final balance:', currentSaldo);
  
  return {
    transactionsProcessed: transactionsProcessed,
    finalBalance: currentSaldo,
    manualEntriesPreserved: manualEntries.length,
    masukTransactions: masukCount,
    keluarTransactions: keluarCount,
    startingBalance: 0
  };
}

// UTILITY: Manual function untuk verify data keuangan sebelum rebuild
function verifyKeuanganBeforeRebuild() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const keuanganSheet = ss.getSheetByName('KEUANGAN');
    
    const data = keuanganSheet.getDataRange().getValues().slice(2);
    
    let report = '=== VERIFIKASI DATA KEUANGAN ===\n\n';
    let invalidCount = 0;
    let manualCount = 0;
    let transactionCount = 0;
    
    data.forEach((row, index) => {
      const rowNum = index + 3;
      const tanggal = row[0];
      const keterangan = row[1] ? row[1].toString() : '';
      const tipe = row[2];
      const jumlah = row[3];
      
      // Check for invalid data
      if (!tanggal || !keterangan || !tipe || !jumlah) {
        report += `❌ Row ${rowNum}: Data tidak lengkap\n`;
        invalidCount++;
        return;
      }
      
      // Check date validity
      const dateObj = new Date(tanggal);
      if (isNaN(dateObj.getTime()) || dateObj.getFullYear() < 2000) {
        report += `❌ Row ${rowNum}: Tanggal tidak valid (${tanggal})\n`;
        invalidCount++;
        return;
      }
      
      // Categorize
      const keteranganLower = keterangan.toLowerCase();
      if (!keteranganLower.includes('beli') && !keteranganLower.includes('jual')) {
        manualCount++;
      } else {
        transactionCount++;
      }
    });
    
    report += `\n=== SUMMARY ===\n`;
    report += `Total rows: ${data.length}\n`;
    report += `Manual entries: ${manualCount}\n`;
    report += `Transaction entries: ${transactionCount}\n`;
    report += `Invalid rows: ${invalidCount}\n\n`;
    
    if (invalidCount > 0) {
      report += `⚠️ PERHATIAN: ${invalidCount} baris data tidak valid akan dihapus saat rebuild!\n`;
    } else {
      report += `✅ Semua data valid, aman untuk rebuild.\n`;
    }
    
    Browser.msgBox('Verifikasi Data Keuangan', report, Browser.Buttons.OK);
    
    return {
      totalRows: data.length,
      manualEntries: manualCount,
      transactions: transactionCount,
      invalidRows: invalidCount
    };
    
  } catch (error) {
    Browser.msgBox('Error', 'Verifikasi gagal: ' + error.toString(), Browser.Buttons.OK);
  }
}

