    console.error('onEdit trigger error:', error);
  }
}

// Fungsi untuk sync KEUANGAN dengan BARANG_MASUK dan BARANG_KELUAR
function syncKeuanganWithTransactions() {
  try {
    console.log('Starting KEUANGAN sync...');
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    
    // Rebuild keuangan chronologically
    rebuildKeuanganChronologically(ss);
    
    // Update stok juga
    updateStokRealOptimized();
    
    console.log('KEUANGAN sync completed');
    
    return {
      success: true,
      message: 'KEUANGAN berhasil di-sync dengan transaksi!'
    };
    
  } catch (error) {
    console.error('syncKeuanganWithTransactions error:', error);
    return {
      success: false,
      message: 'Error syncing KEUANGAN: ' + error.toString()
    };
  }
}

// Fungsi manual untuk rebuild KEUANGAN (bisa dipanggil dari menu)
function manualRebuildKeuangan() {
  try {
    const confirm = Browser.msgBox('Rebuild KEUANGAN', 
      '⚠️ Proses ini akan:\n\n' +
      '1. Backup data KEUANGAN yang ada\n' +
      '2. Rebuild KEUANGAN dari BARANG_MASUK dan BARANG_KELUAR\n' +
      '3. Preserve entry manual (modal, dll)\n' +
      '4. Recalculate semua saldo secara kronologis\n\n' +
      'Lanjutkan?', 
      Browser.Buttons.YES_NO);
    
    if (confirm !== 'yes') return;
    
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    
    // Create backup
    const timestamp = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyyMMdd_HHmmss');
    const backupFile = ss.copy(`BACKUP_KEUANGAN_${timestamp}`);
    
    // Rebuild keuangan
    const rebuildResult = rebuildKeuanganChronologically(ss);
    
    // Update stok
    updateStokRealOptimized();
    
    const successMessage = 
      `✅ KEUANGAN BERHASIL DI-REBUILD!\n\n` +
      `📋 Backup: ${backupFile.getName()}\n` +
      `💰 Transaksi diproses: ${rebuildResult.transactionsProcessed}\n` +
      `💵 Saldo akhir: ${formatRupiah(rebuildResult.finalBalance)}\n` +
      `📝 Entry manual preserved: ${rebuildResult.manualEntriesPreserved}\n\n` +
      `Sekarang KEUANGAN sudah sinkron dengan BARANG_MASUK/KELUAR!`;
    
    Browser.msgBox('Rebuild Complete!', successMessage, Browser.Buttons.OK);
    
    return {
      success: true,
      backup: backupFile.getName(),
      result: rebuildResult
    };
    
  } catch (error) {
    Browser.msgBox('Error', 'Rebuild gagal: ' + error.toString(), Browser.Buttons.OK);
    return { success: false, message: error.toString() };
  }
}

// UPDATE: Improved rebuildKeuanganChronologically dengan better manual entry detection
function rebuildKeuanganChronologically(ss) {
  const keuanganSheet = ss.getSheetByName('KEUANGAN');
  const masukSheet = ss.getSheetByName('BARANG_MASUK');
  const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
  const produkSheet = ss.getSheetByName('MASTER_PRODUK');
  
  console.log('Starting keuangan rebuild...');
  
  // Backup existing keuangan data
  const existingKeuanganData = keuanganSheet.getDataRange().getValues();
  
  // Cari entry manual (yang bukan dari transaksi barang)
  const manualEntries = [];
  existingKeuanganData.slice(2).forEach((row, index) => {
    const keterangan = row[1] ? row[1].toString().toLowerCase() : '';
    
    // Manual entry = bukan "beli" dan bukan "jual"
    if (!keterangan.includes('beli') && !keterangan.includes('jual')) {
      manualEntries.push({
        rowIndex: index + 3,
        data: row,
        date: new Date(row[0])
      });
    }
  });
  
  console.log('Found manual entries:', manualEntries.length);
  
  // Clear keuangan (keep title and header)
  if (keuanganSheet.getLastRow() > 2) {
    keuanganSheet.getRange(3, 1, keuanganSheet.getLastRow() - 2, 6).clearContent();
  }
  
  // Get product mapping untuk display name
  const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
  const hasProductID = headers.includes('Product_ID');
  const produkData = produkSheet.getDataRange().getValues().slice(3);
  const productMapping = {};
  
  produkData.forEach(row => {
    if (hasProductID && row[0] && row[1]) {
      productMapping[row[0]] = row[1]; // Product_ID -> Kode
      productMapping[row[1]] = row[1]; // Kode -> Kode
    } else if (row[0]) {
      productMapping[row[0]] = row[0]; // Kode -> Kode
    }
  });
  
  // Collect all transactions
  const allTransactions = [];
  
  // Add manual entries back
  manualEntries.forEach(entry => {
    allTransactions.push({
      date: entry.date,
      keterangan: entry.data[1],
      tipe: entry.data[2],
      jumlah: entry.data[3],
      refNo: entry.data[5],
      type: 'manual'
    });
  });
  
  // Add barang masuk (as pengeluaran)
  const masukData = masukSheet.getDataRange().getValues().slice(2);
  masukData.forEach(row => {
    if (row[0] && row[3] && row[6]) {
      const displayCode = productMapping[row[3]] || row[3];
      allTransactions.push({
        date: new Date(row[0]),
        keterangan: `Beli ${displayCode} dari ${row[2]}`,
        tipe: 'Keluar',
        jumlah: row[6],
        refNo: row[1],
        type: 'masuk'
      });
    }
  });
  
  // Add barang keluar (as pemasukan)
  const keluarData = keluarSheet.getDataRange().getValues().slice(2);
  keluarData.forEach(row => {
    if (row[0] && row[3] && row[6]) {
      const displayCode = productMapping[row[3]] || row[3];
      allTransactions.push({
        date: new Date(row[0]),
        keterangan: `Jual ${displayCode} ke ${row[2]}`,
        tipe: 'Masuk',
        jumlah: row[6],
        refNo: row[1],
        type: 'keluar'
      });
    }
  });
  
  console.log('Total transactions:', allTransactions.length);
  
  // Sort by date
  allTransactions.sort((a, b) => a.date - b.date);
  
  // Rebuild with running balance
  let currentSaldo = 0;
  let transactionsProcessed = 0;
  
  allTransactions.forEach(transaction => {
    // Calculate balance
    if (transaction.tipe === 'Masuk') {
      currentSaldo += transaction.jumlah;
    } else {
      currentSaldo -= transaction.jumlah;
    }
    
    // Create row
    const keuanganRow = [
      Utilities.formatDate(transaction.date, Session.getScriptTimeZone(), 'yyyy-MM-dd HH:mm:ss'),
      transaction.keterangan,
      transaction.tipe,
      transaction.jumlah,
      currentSaldo,
      transaction.refNo || '-'
    ];
    
    keuanganSheet.appendRow(keuanganRow);
    
    // Format
    const lastRow = keuanganSheet.getLastRow();
    simpleFormat('KEUANGAN', lastRow);
    
    transactionsProcessed++;
  });
  
  console.log('Keuangan rebuild completed');
  
  return {
    transactionsProcessed: transactionsProcessed,
    finalBalance: currentSaldo,
    manualEntriesPreserved: manualEntries.length,
    startingBalance: 0
  };
}


function sortBarangMasukByDate() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const masukSheet = ss.getSheetByName('BARANG_MASUK');
    
    if (!masukSheet) {
      Browser.msgBox('Error', 'Sheet BARANG_MASUK tidak ditemukan!', Browser.Buttons.OK);
      return { success: false, message: 'Sheet not found' };
    }
    
    const lastRow = masukSheet.getLastRow();
    
    // Jika tidak ada data (hanya title dan header), skip
    if (lastRow <= 2) {
      Browser.msgBox('Info', 'BARANG_MASUK tidak memiliki data untuk diurutkan.', Browser.Buttons.OK);
      return { success: true, message: 'No data to sort' };
    }
    
    // Get data range (skip title row 1 and header row 2)
    const dataRange = masukSheet.getRange(3, 1, lastRow - 2, masukSheet.getLastColumn());
    
    // Sort by column 1 (Tanggal), ascending
    dataRange.sort({column: 1, ascending: true});
    
    Browser.msgBox('Success', `BARANG_MASUK berhasil diurutkan! (${lastRow - 2} baris data)`, Browser.Buttons.OK);
    
    return { 
      success: true, 
      message: 'BARANG_MASUK sorted successfully',
      rowsSorted: lastRow - 2
    };
    
  } catch (error) {
    Browser.msgBox('Error', 'Gagal mengurutkan BARANG_MASUK: ' + error.toString(), Browser.Buttons.OK);
    return { success: false, message: error.toString() };
  }
}

function sortBarangKeluarByDate() {
