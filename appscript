// ========== PRODUCT_ID SYSTEM FUNCTIONS ==========

function setupProductIDSystem() {
  try {
    console.log('Setting up Product_ID system...');
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const produkSheet = ss.getSheetByName('MASTER_PRODUK');
    
    if (!produkSheet) {
      return { success: false, message: 'MASTER_PRODUK sheet not found' };
    }
    
    // Cek apakah kolom Product_ID sudah ada
    const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
    if (headers.includes('Product_ID')) {
      return { success: false, message: 'Product_ID system already exists' };
    }
    
    // Insert kolom baru di posisi A (menggeser semua ke kanan)
    produkSheet.insertColumnBefore(1);
    
    // Update header
    produkSheet.getRange(1, 1, 1, produkSheet.getLastColumn()).merge();
    produkSheet.getRange(1, 1).setValue('DATA MASTER PRODUK');
    produkSheet.getRange(2, 1).setValue('Product_ID');
    produkSheet.getRange(2, 2).setValue('Kode');
    produkSheet.getRange(2, 3).setValue('Nama_Produk');
    produkSheet.getRange(2, 4).setValue('Kemasan');
    produkSheet.getRange(2, 5).setValue('Harga_Ref');
    produkSheet.getRange(2, 6).setValue('Min_Stok');
    produkSheet.getRange(2, 7).setValue('Status');
    
    // Generate unique IDs untuk produk yang ada
    const data = produkSheet.getDataRange().getValues();
    let idCounter = 1;
    
    for (let i = 3; i < data.length; i++) { // Start from row 4 (after title, header, note)
      if (data[i][1] && data[i][1] !== '') { // Jika ada kode produk di kolom B (dulu kolom A)
        const uniqueId = `PID${String(idCounter).padStart(3, '0')}`; // PID001, PID002, etc.
        produkSheet.getRange(i + 1, 1).setValue(uniqueId);
        idCounter++;
      }
    }
    
    // Format header baru
    try {
      formatSheetHeader(produkSheet, produkSheet.getRange('A2:G2'), produkSheet.getRange('A1:G1'), '#34a853');
    } catch (formatError) {
      console.log('Header format error:', formatError.toString());
    }
    
    console.log('Product_ID system setup completed');
    
    return { 
      success: true, 
      message: 'Product_ID system berhasil disetup! Sekarang setiap produk memiliki ID unik yang permanen.',
      productsUpdated: idCounter - 1
    };
    
  } catch (error) {
    console.error('setupProductIDSystem error:', error.toString());
    return { 
      success: false, 
      message: 'Setup Product_ID failed: ' + error.toString() 
    };
  }
}

// ========== DATA MIGRATION FUNCTIONS ==========

function migrateExistingData() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const produkSheet = ss.getSheetByName('MASTER_PRODUK');
    const masukSheet = ss.getSheetByName('BARANG_MASUK');
    const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
    
    // Cek apakah Product_ID sudah ada
    const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
    if (!headers.includes('Product_ID')) {
      throw new Error('Product_ID system belum disetup. Jalankan setupProductIDSystem() dulu.');
    }
    
    console.log('Starting data migration...');
    
    // Buat mapping dari kode lama ke Product_ID
    const produkData = produkSheet.getDataRange().getValues().slice(3); // Skip title, header, note
    const kodeToProductID = {};
    
    produkData.forEach(row => {
      const productID = row[0]; // Product_ID di kolom A
      const kode = row[1];      // Kode di kolom B
      if (productID && kode) {
        kodeToProductID[kode] = productID;
      }
    });
    
    console.log('Product mapping created:', kodeToProductID);
    
    let updatedMasuk = 0;
    let updatedKeluar = 0;
    
    // Update BARANG_MASUK - ganti kode dengan Product_ID
    const masukData = masukSheet.getDataRange().getValues();
    for (let i = 2; i < masukData.length; i++) { // Skip title and header
      const currentKode = masukData[i][3]; // Column D = Kode_Produk
      const productID = kodeToProductID[currentKode];
      
      if (productID && currentKode !== productID) {
        masukSheet.getRange(i + 1, 4).setValue(productID); // Update to Product_ID
        updatedMasuk++;
        console.log(`Updated MASUK row ${i + 1}: ${currentKode} → ${productID}`);
      }
    }
    
    // Update BARANG_KELUAR - ganti kode dengan Product_ID
    const keluarData = keluarSheet.getDataRange().getValues();
    for (let i = 2; i < keluarData.length; i++) { // Skip title and header
      const currentKode = keluarData[i][3]; // Column D = Kode_Produk
      const productID = kodeToProductID[currentKode];
      
      if (productID && currentKode !== productID) {
        keluarSheet.getRange(i + 1, 4).setValue(productID); // Update to Product_ID
        updatedKeluar++;
        console.log(`Updated KELUAR row ${i + 1}: ${currentKode} → ${productID}`);
      }
    }
    
    // Update header labels untuk clarity
    masukSheet.getRange(2, 4).setValue('Product_Ref'); // Was Kode_Produk
    keluarSheet.getRange(2, 4).setValue('Product_Ref'); // Was Kode_Produk
    
    // Refresh stok
    updateStokRealOptimized();
    
    const message = `✅ Migrasi berhasil!\n\n` +
                   `📥 BARANG_MASUK: ${updatedMasuk} records updated\n` +
                   `📤 BARANG_KELUAR: ${updatedKeluar} records updated\n\n` +
                   `Sekarang semua transaksi menggunakan Product_ID yang stabil.`;
    
    Browser.msgBox('Migration Complete!', message, Browser.Buttons.OK);
    
    return {
      success: true,
      message: message,
      stats: {
        updatedMasuk: updatedMasuk,
        updatedKeluar: updatedKeluar,
        mappings: Object.keys(kodeToProductID).length
      }
    };
    
  } catch (error) {
    const errorMsg = 'Migration failed: ' + error.toString();
    Browser.msgBox('Migration Error', errorMsg, Browser.Buttons.OK);
    console.error('Migration error:', error);
    return {
      success: false,
      message: errorMsg
    };
  }
}

function rollbackMigration() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const produkSheet = ss.getSheetByName('MASTER_PRODUK');
    const masukSheet = ss.getSheetByName('BARANG_MASUK');
    const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
    
    const confirm = Browser.msgBox('Rollback Confirmation', 
      'Apakah yakin ingin rollback ke system kode lama?\n\nIni akan:\n- Menghapus kolom Product_ID\n- Mengembalikan semua referensi ke kode produk\n- TIDAK BISA DI-UNDO!', 
      Browser.Buttons.YES_NO);
    
    if (confirm !== 'yes') return;
    
    // Buat mapping dari Product_ID ke kode
    const produkData = produkSheet.getDataRange().getValues().slice(3);
    const productIDToKode = {};
    
    produkData.forEach(row => {
      const productID = row[0];
      const kode = row[1];
      if (productID && kode) {
        productIDToKode[productID] = kode;
      }
    });
    
    // Update transaksi masuk
    const masukData = masukSheet.getDataRange().getValues();
    for (let i = 2; i < masukData.length; i++) {
      const currentRef = masukData[i][3];
      const kode = productIDToKode[currentRef];
      
      if (kode && currentRef !== kode) {
        masukSheet.getRange(i + 1, 4).setValue(kode);
      }
    }
    
    // Update transaksi keluar
    const keluarData = keluarSheet.getDataRange().getValues();
    for (let i = 2; i < keluarData.length; i++) {
      const currentRef = keluarData[i][3];
      const kode = productIDToKode[currentRef];
      
      if (kode && currentRef !== kode) {
        keluarSheet.getRange(i + 1, 4).setValue(kode);
      }
    }
    
    // Hapus kolom Product_ID dari MASTER_PRODUK
    produkSheet.deleteColumn(1);
    
    // Update headers
    produkSheet.getRange(2, 1).setValue('Kode');
    masukSheet.getRange(2, 4).setValue('Kode_Produk');
    keluarSheet.getRange(2, 4).setValue('Kode_Produk');
    
    // Refresh stok
    updateStokRealOptimized();
    
    Browser.msgBox('Rollback Complete!', 
      '✅ System berhasil dikembalikan ke kode lama.\n\nSemua Product_ID sudah dihapus dan diganti dengan kode asli.', 
      Browser.Buttons.OK);
    
  } catch (error) {
    Browser.msgBox('Rollback Error', 'Rollback failed: ' + error.toString(), Browser.Buttons.OK);
  }
}

// ========== DATA VALIDATION & REPAIR FUNCTIONS ==========

function cleanOrphanedProductCodes() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const produkSheet = ss.getSheetByName('MASTER_PRODUK');
    const masukSheet = ss.getSheetByName('BARANG_MASUK');
    const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
    
    // Ambil semua kode produk yang valid dari master
    const produkData = produkSheet.getDataRange().getValues().slice(3); // Skip title, header, note
    const validCodes = new Set();
    
    // Check if using Product_ID system
    const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
    const hasProductID = headers.includes('Product_ID');
    
    produkData.forEach(row => {
      if (hasProductID) {
        validCodes.add(row[0]); // Product_ID
        validCodes.add(row[1]); // Kode
      } else {
        validCodes.add(row[0]); // Kode only
      }
    });
    
    // Cari kode orphan di transaksi masuk
    const masukData = masukSheet.getDataRange().getValues().slice(2); // Skip title, header
    const orphanedMasuk = [];
    masukData.forEach((row, index) => {
      const code = row[3]; // Column D = Kode_Produk/Product_Ref
      if (code && !validCodes.has(code)) {
        orphanedMasuk.push({row: index + 3, code: code, data: row});
      }
    });
    
    // Cari kode orphan di transaksi keluar
    const keluarData = keluarSheet.getDataRange().getValues().slice(2); // Skip title, header
    const orphanedKeluar = [];
    keluarData.forEach((row, index) => {
      const code = row[3]; // Column D = Kode_Produk/Product_Ref
      if (code && !validCodes.has(code)) {
        orphanedKeluar.push({row: index + 3, code: code, data: row});
      }
    });
    
    if (orphanedMasuk.length === 0 && orphanedKeluar.length === 0) {
      Browser.msgBox('Bersih!', 'Tidak ada kode produk orphan ditemukan.', Browser.Buttons.OK);
      return;
    }
    
    // Tampilkan laporan
    let report = 'DITEMUKAN KODE PRODUK ORPHAN:\n\n';
    
    if (orphanedMasuk.length > 0) {
      report += `📥 BARANG MASUK (${orphanedMasuk.length} record):\n`;
      orphanedMasuk.forEach(item => {
        report += `- Row ${item.row}: ${item.code} (${item.data[1]}, ${item.data[2]})\n`;
      });
      report += '\n';
    }
    
    if (orphanedKeluar.length > 0) {
      report += `📤 BARANG KELUAR (${orphanedKeluar.length} record):\n`;
      orphanedKeluar.forEach(item => {
        report += `- Row ${item.row}: ${item.code} (${item.data[1]}, ${item.data[2]})\n`;
      });
    }
    
    report += '\nSilakan perbaiki manual atau gunakan fungsi Fix Corrupted Data';
    
    Browser.msgBox('Laporan Orphan Code', report, Browser.Buttons.OK);
    
  } catch (error) {
    Browser.msgBox('Error', 'Terjadi kesalahan: ' + error.toString(), Browser.Buttons.OK);
  }
}

function fixCorruptedData() {
  try {
    console.log('Starting corrupted data fix...');
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    
    // Step 1: Backup dulu
    const timestamp = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyyMMdd_HHmmss');
    const backupFile = ss.copy(`BACKUP_BEFORE_FIX_${timestamp}`);
    console.log('Backup created:', backupFile.getName());
    
    // Step 2: Analisis masalah
    const analysisResult = analyzeDataIntegrity();
    console.log('Analysis result:', analysisResult);
    
    if (analysisResult.criticalIssues.length === 0) {
      Browser.msgBox('Data Check', 'Data sudah konsisten, tidak perlu perbaikan.', Browser.Buttons.OK);
      return;
    }
    
    // Step 3: Tampilkan report masalah
    let reportMessage = 'MASALAH YANG DITEMUKAN:\n\n';
    analysisResult.criticalIssues.forEach((issue, index) => {
      reportMessage += `${index + 1}. ${issue}\n`;
    });
    reportMessage += '\nApakah ingin melanjutkan perbaikan otomatis?';
    
    const confirm = Browser.msgBox('Data Integrity Issues', reportMessage, Browser.Buttons.YES_NO);
    if (confirm !== 'yes') return;
    
    // Step 4: Setup Product_ID system jika belum ada
    const produkSheet = ss.getSheetByName('MASTER_PRODUK');
    const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
    
    if (!headers.includes('Product_ID')) {
      console.log('Setting up Product_ID system...');
      const setupResult = setupProductIDSystem();
      if (!setupResult.success) {
        throw new Error('Failed to setup Product_ID: ' + setupResult.message);
      }
    }
    
    // Step 5: Buat mapping yang benar
    const correctMapping = createCorrectMapping();
    console.log('Correct mapping created:', correctMapping);
    
    // Step 6: Fix transaksi yang salah
    const fixResults = fixTransactionReferences(correctMapping);
    console.log('Fix results:', fixResults);
    
    // Step 7: Rebuild stok dari awal
    updateStokRealOptimized();
    
    // Step 8: Final verification
    const finalCheck = analyzeDataIntegrity();
    
    const successMessage = `✅ PERBAIKAN BERHASIL!\n\n` +
                          `📋 Backup: ${backupFile.getName()}\n` +
                          `🔧 Fixed MASUK: ${fixResults.fixedMasuk} records\n` +
                          `🔧 Fixed KELUAR: ${fixResults.fixedKeluar} records\n` +
                          `📊 Remaining issues: ${finalCheck.criticalIssues.length}\n\n` +
                          `Data sekarang menggunakan Product_ID yang stabil.`;
    
    Browser.msgBox('Fix Complete!', successMessage, Browser.Buttons.OK);
    
    return {
      success: true,
      message: successMessage,
      backup: backupFile.getName(),
      fixResults: fixResults
    };
    
  } catch (error) {
    Browser.msgBox('Fix Error', 'Perbaikan gagal: ' + error.toString(), Browser.Buttons.OK);
    return { success: false, message: error.toString() };
  }
}

function analyzeDataIntegrity() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const produkSheet = ss.getSheetByName('MASTER_PRODUK');
  const masukSheet = ss.getSheetByName('BARANG_MASUK');
  const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
  
  const criticalIssues = [];
  const warnings = [];
  
  // Check 1: Product_ID system
  const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
  if (!headers.includes('Product_ID')) {
    criticalIssues.push('Product_ID system belum disetup');
  }
  
  // Check 2: Orphaned product codes
  const validCodes = new Set();
  const produkData = produkSheet.getDataRange().getValues().slice(3);
  
  produkData.forEach(row => {
    if (headers.includes('Product_ID')) {
      validCodes.add(row[0]); // Product_ID
      validCodes.add(row[1]); // Kode
    } else {
      validCodes.add(row[0]); // Kode only
    }
  });
  
  // Check transactions for orphaned codes
  const masukData = masukSheet.getDataRange().getValues().slice(2);
  const keluarData = keluarSheet.getDataRange().getValues().slice(2);
  
  let orphanedMasuk = 0;
  let orphanedKeluar = 0;
  
  masukData.forEach(row => {
    if (row[3] && !validCodes.has(row[3])) {
      orphanedMasuk++;
    }
  });
  
  keluarData.forEach(row => {
    if (row[3] && !validCodes.has(row[3])) {
      orphanedKeluar++;
    }
  });
  
  if (orphanedMasuk > 0) {
    criticalIssues.push(`${orphanedMasuk} transaksi MASUK dengan kode produk tidak valid`);
  }
  
  if (orphanedKeluar > 0) {
    criticalIssues.push(`${orphanedKeluar} transaksi KELUAR dengan kode produk tidak valid`);
  }
  
  return {
    criticalIssues,
    warnings,
    stats: {
      totalProducts: produkData.length,
      totalMasuk: masukData.length,
      totalKeluar: keluarData.length,
      orphanedMasuk,
      orphanedKeluar
    }
  };
}

function createCorrectMapping() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const produkSheet = ss.getSheetByName('MASTER_PRODUK');
  
  const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
  const produkData = produkSheet.getDataRange().getValues().slice(3);
  
  const mapping = {
    codeToProductID: {},
    productIDToCode: {},
    validReferences: new Set()
  };
  
  produkData.forEach(row => {
    if (headers.includes('Product_ID')) {
      const productID = row[0];
      const code = row[1];
      
      if (productID && code) {
        mapping.codeToProductID[code] = productID;
        mapping.productIDToCode[productID] = code;
        mapping.validReferences.add(productID);
        mapping.validReferences.add(code);
      }
    } else {
      const code = row[0];
      if (code) {
        mapping.validReferences.add(code);
      }
    }
  });
  
  return mapping;
}

function fixTransactionReferences(mapping) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const masukSheet = ss.getSheetByName('BARANG_MASUK');
  const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
  
  let fixedMasuk = 0;
  let fixedKeluar = 0;
  
  // Fix BARANG_MASUK
  const masukData = masukSheet.getDataRange().getValues();
  for (let i = 2; i < masukData.length; i++) {
    const currentRef = masukData[i][3];
    
    if (!mapping.validReferences.has(currentRef)) {
      // Try to find similar code
      const possibleMatches = Object.keys(mapping.codeToProductID).filter(code => 
        code.toLowerCase().includes(currentRef.toLowerCase()) ||
        currentRef.toLowerCase().includes(code.toLowerCase())
      );
      
      if (possibleMatches.length === 1) {
        const correctProductID = mapping.codeToProductID[possibleMatches[0]];
        masukSheet.getRange(i + 1, 4).setValue(correctProductID);
        fixedMasuk++;
        console.log(`Fixed MASUK row ${i + 1}: ${currentRef} → ${correctProductID}`);
      }
    } else if (mapping.codeToProductID[currentRef]) {
      // Convert code to Product_ID if needed
      const productID = mapping.codeToProductID[currentRef];
      masukSheet.getRange(i + 1, 4).setValue(productID);
      fixedMasuk++;
    }
  }
  
  // Fix BARANG_KELUAR
  const keluarData = keluarSheet.getDataRange().getValues();
  for (let i = 2; i < keluarData.length; i++) {
    const currentRef = keluarData[i][3];
    
    if (!mapping.validReferences.has(currentRef)) {
      // Try to find similar code
      const possibleMatches = Object.keys(mapping.codeToProductID).filter(code => 
        code.toLowerCase().includes(currentRef.toLowerCase()) ||
        currentRef.toLowerCase().includes(code.toLowerCase())
      );
      
      if (possibleMatches.length === 1) {
        const correctProductID = mapping.codeToProductID[possibleMatches[0]];
        keluarSheet.getRange(i + 1, 4).setValue(correctProductID);
        fixedKeluar++;
        console.log(`Fixed KELUAR row ${i + 1}: ${currentRef} → ${correctProductID}`);
      }
    } else if (mapping.codeToProductID[currentRef]) {
      // Convert code to Product_ID if needed
      const productID = mapping.codeToProductID[currentRef];
      keluarSheet.getRange(i + 1, 4).setValue(productID);
      fixedKeluar++;
    }
  }
  
  return { fixedMasuk, fixedKeluar };
}

function findMissingProducts() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const produkSheet = ss.getSheetByName('MASTER_PRODUK');
  const masukSheet = ss.getSheetByName('BARANG_MASUK');
  const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
  
  // Get valid product references
  const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
  const produkData = produkSheet.getDataRange().getValues().slice(3);
  const validRefs = new Set();
  
  produkData.forEach(row => {
    if (headers.includes('Product_ID')) {
      validRefs.add(row[0]); // Product_ID
      validRefs.add(row[1]); // Code
    } else {
      validRefs.add(row[0]); // Code only
    }
  });
  
  // Find all references in transactions
  const allTransactionRefs = new Set();
  
  masukSheet.getDataRange().getValues().slice(2).forEach(row => {
    if (row[3]) allTransactionRefs.add(row[3]);
  });
  
  keluarSheet.getDataRange().getValues().slice(2).forEach(row => {
    if (row[3]) allTransactionRefs.add(row[3]);
  });
  
  // Find missing products
  const missingProducts = [];
  allTransactionRefs.forEach(ref => {
    if (!validRefs.has(ref)) {
      missingProducts.push(ref);
    }
  });
  
  if (missingProducts.length > 0) {
    const message = `PRODUK TIDAK DITEMUKAN DI MASTER:\n\n${missingProducts.join('\n')}\n\nTambahkan produk ini ke MASTER_PRODUK atau perbaiki referensi di transaksi.`;
    Browser.msgBox('Missing Products', message, Browser.Buttons.OK);
  } else {
    Browser.msgBox('Check Complete', 'Semua produk di transaksi sudah ada di master.', Browser.Buttons.OK);
  }
  
  return missingProducts;
}

