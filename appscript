function getAverageCostsOptimized() {
  try {
    console.log('Starting getAverageCostsOptimized with Product_ID support...');
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const masukSheet = ss.getSheetByName('BARANG_MASUK');
    const produkSheet = ss.getSheetByName('MASTER_PRODUK');
    
    if (!masukSheet || !produkSheet) {
      return { success: false, message: 'Required sheets not found' };
    }
    
    // Cek apakah menggunakan Product_ID system
    const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
    const hasProductID = headers.includes('Product_ID');
    
    const allData = masukSheet.getDataRange().getValues();
    
    if (allData.length <= 2) {
      return { 
        success: true, 
        data: {},
        message: 'No purchase data yet'
      };
    }
    
    const masukData = allData.slice(2);
    const produkData = produkSheet.getDataRange().getValues().slice(3);
    
    // Create mapping dari Product_ID/Kode ke display kode
    const productMapping = {};
    produkData.forEach(row => {
      if (hasProductID && row[0] && row[1]) {
        productMapping[row[0]] = row[1]; // Product_ID -> Kode
        productMapping[row[1]] = row[1]; // Kode -> Kode (untuk backward compatibility)
      } else if (row[0]) {
        productMapping[row[0]] = row[0]; // Kode -> Kode (legacy)
      }
    });
    
    const costData = {};
    
    masukData.forEach((row, index) => {
      if (!row || row.length < 7) return;
      
      const [tanggal, invoice, supplier, productRef, qty, harga, total] = row;
      
      if (!productRef || qty === '' || harga === '') return;
      
      // Convert ke display kode
      const displayCode = productMapping[productRef] || productRef;
      
      let quantity = 0;
      let price = 0;
      
      try {
        quantity = parseInt(qty) || parseFloat(qty) || 0;
        price = parseInt(harga) || parseFloat(harga) || 0;
      } catch (e) {
        return;
      }
      
      if (quantity > 0 && price > 0) {
        if (!costData[displayCode]) {
          costData[displayCode] = {
            totalValue: 0,
            totalQty: 0,
            avgCost: 0,
            transactions: [],
            lastPrice: 0,
            priceCount: 0
          };
        }
        
        const value = quantity * price;
        
        costData[displayCode].totalValue += value;
        costData[displayCode].totalQty += quantity;
        costData[displayCode].priceCount++;
        costData[displayCode].lastPrice = price;
        
        costData[displayCode].transactions.push({
          tanggal: tanggal,
          qty: quantity,
          harga: price,
          supplier: supplier,
          invoice: invoice
        });
      }
    });
    
    // Calculate weighted average costs
    Object.keys(costData).forEach(kode => {
      const data = costData[kode];
      if (data.totalQty > 0) {
        data.avgCost = Math.round(data.totalValue / data.totalQty);
      }
    });
    
    return {
      success: true,
      data: costData,
      hasProductID: hasProductID
    };
  } catch (error) {
    console.error('getAverageCostsOptimized error:', error);
    return { 
      success: false, 
      message: 'Error calculating average costs: ' + error.toString() 
    };
  }
}

