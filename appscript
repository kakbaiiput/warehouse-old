function sortAllTransactionsByDate() {
  try {
    console.log('Sorting all transactions by date...');
    
    const resultMasuk = sortBarangMasukByDate();
    const resultKeluar = sortBarangKeluarByDate();
    
    if (resultMasuk.success && resultKeluar.success) {
      const totalRows = (resultMasuk.rowsSorted || 0) + (resultKeluar.rowsSorted || 0);
      Browser.msgBox('Success', 
        `Semua transaksi berhasil diurutkan berdasarkan tanggal!\n\n` +
        `BARANG_MASUK: ${resultMasuk.rowsSorted || 0} baris\n` +
        `BARANG_KELUAR: ${resultKeluar.rowsSorted || 0} baris\n` +
        `Total: ${totalRows} baris`, 
        Browser.Buttons.OK);
      
      return {
        success: true,
        message: 'All transactions sorted',
        masukRows: resultMasuk.rowsSorted || 0,
        keluarRows: resultKeluar.rowsSorted || 0
      };
    } else {
      return {
        success: false,
        message: 'Some sheets failed to sort'
      };
    }
    
  } catch (error) {
    Browser.msgBox('Error', 'Gagal mengurutkan transaksi: ' + error.toString(), Browser.Buttons.OK);
    return { success: false, message: error.toString() };
  }
}

// ENHANCED: Auto-sort after save (untuk dipanggil dari save functions)
function autoSortAfterTransaction(sheetName) {
  try {
    console.log(`Auto-sorting ${sheetName} after transaction...`);
    
    if (sheetName === 'BARANG_MASUK') {
      const ss = SpreadsheetApp.getActiveSpreadsheet();
      const masukSheet = ss.getSheetByName('BARANG_MASUK');
      
      if (masukSheet && masukSheet.getLastRow() > 2) {
        const dataRange = masukSheet.getRange(3, 1, masukSheet.getLastRow() - 2, masukSheet.getLastColumn());
        dataRange.sort({column: 1, ascending: true});
        console.log('BARANG_MASUK auto-sorted');
      }
    } else if (sheetName === 'BARANG_KELUAR') {
      const ss = SpreadsheetApp.getActiveSpreadsheet();
      const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
      
      if (keluarSheet && keluarSheet.getLastRow() > 2) {
        const dataRange = keluarSheet.getRange(3, 1, keluarSheet.getLastRow() - 2, keluarSheet.getLastColumn());
        dataRange.sort({column: 1, ascending: true});
        console.log('BARANG_KELUAR auto-sorted');
      }
    }
  } catch (error) {
    console.error('Auto-sort error:', error);
    // Don't throw error, just log it
  }
}

function manualSortTransactions() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    
    // Sort BARANG_MASUK
    const masukSheet = ss.getSheetByName('BARANG_MASUK');
    if (masukSheet && masukSheet.getLastRow() > 2) {
      const dataRange = masukSheet.getRange(3, 1, masukSheet.getLastRow() - 2, masukSheet.getLastColumn());
      dataRange.sort({column: 1, ascending: false}); // Sort descending by date
      console.log('BARANG_MASUK sorted');
    }
    
    // Sort BARANG_KELUAR
    const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
    if (keluarSheet && keluarSheet.getLastRow() > 2) {
      const dataRange = keluarSheet.getRange(3, 1, keluarSheet.getLastRow() - 2, keluarSheet.getLastColumn());
      dataRange.sort({column: 1, ascending: false}); // Sort descending by date
      console.log('BARANG_KELUAR sorted');
    }
    
    Browser.msgBox('Sort Complete!', 
      '✅ Transaksi berhasil diurutkan berdasarkan tanggal!\n\n' +
      'BARANG_MASUK dan BARANG_KELUAR sekarang tersort dari yang terbaru.', 
      Browser.Buttons.OK);
    
    return { success: true, message: 'Transactions sorted by date' };
    
  } catch (error) {
    console.error('manualSortTransactions error:', error);
    Browser.msgBox('Error', 'Gagal sort transaksi: ' + error.toString(), Browser.Buttons.OK);
    return { success: false, message: error.toString() };
  }
}

