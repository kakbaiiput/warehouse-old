    updateStokRealOptimized();
    
    return { 
      success: true, 
      message: `Barang masuk berhasil disimpan! Product: ${productCode}, Waktu: ${transactionDate}` 
    };
    
  } catch (error) {
    return { success: false, message: 'Error: ' + error.toString() };
  }
