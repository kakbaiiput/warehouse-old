// Helper function untuk mendapatkan display name produk
function getProductDisplayName(productRef) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const produkSheet = ss.getSheetByName('MASTER_PRODUK');
    
    if (!produkSheet) return productRef;
    
    const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
    const hasProductID = headers.includes('Product_ID');
    const produkData = produkSheet.getDataRange().getValues().slice(3);
    
    // Cari produk berdasarkan Product_ID atau kode
    const produk = produkData.find(row => {
      if (hasProductID) {
        return row[0] === productRef || row[1] === productRef; // Product_ID atau Kode
      } else {
        return row[0] === productRef; // Kode saja
      }
    });
    
    if (produk) {
      return hasProductID ? produk[1] : produk[0]; // Return display kode
    }
    
    return productRef; // Fallback
  } catch (error) {
    console.error('getProductDisplayName error:', error);
    return productRef;
  }
}

// STEP 4: Verify data integrity setelah repair
function verifyDataIntegrity(ss) {
  const issues = [];
  const warnings = [];
  
  try {
    // Check 1: Verify chronological order
    const masukSheet = ss.getSheetByName('BARANG_MASUK');
    const keluarSheet = ss.getSheetByName('BARANG_KELUAR');
    const keuanganSheet = ss.getSheetByName('KEUANGAN');
    
    // Check BARANG_MASUK chronology
    const masukData = masukSheet.getDataRange().getValues().slice(2);
    for (let i = 1; i < masukData.length; i++) {
      const prevDate = new Date(masukData[i-1][0]);
      const currDate = new Date(masukData[i][0]);
      
      if (currDate < prevDate) {
        issues.push(`BARANG_MASUK row ${i+3}: Date order issue`);
      }
    }
    
    // Check BARANG_KELUAR chronology
    const keluarData = keluarSheet.getDataRange().getValues().slice(2);
    for (let i = 1; i < keluarData.length; i++) {
      const prevDate = new Date(keluarData[i-1][0]);
      const currDate = new Date(keluarData[i][0]);
      
      if (currDate < prevDate) {
        issues.push(`BARANG_KELUAR row ${i+3}: Date order issue`);
      }
    }
    
    // Check KEUANGAN chronology
    const keuanganData = keuanganSheet.getDataRange().getValues().slice(2);
    for (let i = 1; i < keuanganData.length; i++) {
      const prevDate = new Date(keuanganData[i-1][0]);
      const currDate = new Date(keuanganData[i][0]);
      
      if (currDate < prevDate) {
        issues.push(`KEUANGAN row ${i+3}: Date order issue`);
      }
    }
    
    // Check 2: Verify balance calculations
    let calculatedBalance = 0;
    keuanganData.forEach((row, index) => {
      if (row[2] === 'Masuk') {
        calculatedBalance += row[3];
      } else {
        calculatedBalance -= row[3];
      }
      
      const recordedBalance = row[4];
      if (Math.abs(calculatedBalance - recordedBalance) > 1) { // Allow 1 rupiah tolerance
        issues.push(`KEUANGAN row ${index+3}: Balance mismatch (calculated: ${calculatedBalance}, recorded: ${recordedBalance})`);
      }
    });
    
    // Check 3: Count transactions
    const masukCount = masukData.length;
    const keluarCount = keluarData.length;
    const keuanganTransactionCount = keuanganData.filter(row => 
      row[1] && (row[1].toString().includes('Beli') || row[1].toString().includes('Jual'))
    ).length;
    
    const expectedKeuanganCount = masukCount + keluarCount;
    if (Math.abs(keuanganTransactionCount - expectedKeuanganCount) > 2) { // Small tolerance
      warnings.push(`Transaction count mismatch: Expected ${expectedKeuanganCount}, found ${keuanganTransactionCount} in KEUANGAN`);
    }
    
  } catch (error) {
    issues.push(`Verification error: ${error.toString()}`);
  }
  
  return {
    issues: issues,
    warnings: warnings,
    isValid: issues.length === 0
  };
}

// UTILITY: Check data chronology (standalone function)
function checkDataChronology() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const verifyResults = verifyDataIntegrity(ss);
    
    if (verifyResults.isValid && verifyResults.warnings.length === 0) {
      Browser.msgBox('Chronology Check', 
        '✅ Semua data sudah berurutan kronologis dengan baik!\n\n' +
        'Tidak ada masalah yang ditemukan.',
        Browser.Buttons.OK);
    } else {
      let message = '';
      
      if (verifyResults.issues.length > 0) {
        message += `🔴 CRITICAL ISSUES (${verifyResults.issues.length}):\n`;
        verifyResults.issues.slice(0, 5).forEach(issue => {
          message += `• ${issue}\n`;
        });
        if (verifyResults.issues.length > 5) {
          message += `... dan ${verifyResults.issues.length - 5} masalah lainnya\n`;
        }
        message += '\n';
      }
      
      if (verifyResults.warnings.length > 0) {
        message += `🟡 WARNINGS (${verifyResults.warnings.length}):\n`;
        verifyResults.warnings.slice(0, 3).forEach(warning => {
          message += `• ${warning}\n`;
        });
        if (verifyResults.warnings.length > 3) {
          message += `... dan ${verifyResults.warnings.length - 3} warning lainnya\n`;
        }
      }
      
      message += '\nGunakan "Sort Data by Date" untuk memperbaiki masalah chronological.';
      
      Browser.msgBox('Chronology Issues Found', message, Browser.Buttons.OK);
    }
    
    return verifyResults;
    
  } catch (error) {
    Browser.msgBox('Error', 'Error checking chronology: ' + error.toString(), Browser.Buttons.OK);
    return { success: false, message: error.toString() };
  }
}

// UTILITY: Format rupiah for display
function formatRupiah(amount) {
  return 'Rp ' + (amount || 0).toLocaleString('id-ID');
}

// UTILITY: Enhanced simpleFormat function
function simpleFormat(sheetName, rowNumber) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName(sheetName);
    
    if (!sheet || !rowNumber) return;
    
    if (sheetName === 'BARANG_MASUK') {
      formatCurrency(sheet.getRange(rowNumber, 6, 1, 2)); // Harga dan Total
    }
    
    if (sheetName === 'BARANG_KELUAR') {
      formatCurrency(sheet.getRange(rowNumber, 6, 1, 2)); // Harga dan Total
    }
    
    if (sheetName === 'KEUANGAN') {
      formatCurrency(sheet.getRange(rowNumber, 4, 1, 2)); // Jumlah dan Saldo
    }
    
  } catch (error) {
    console.error('Simple format error for', sheetName, ':', error.toString());
  }
}

function formatCurrency(range) {
  try {
    range.setNumberFormat('#,##0');
  } catch (error) {
    console.error('formatCurrency error:', error.toString());
  }
}


// UPDATED: recalculateAllSaldos - start from zero
function recalculateAllSaldos(keuanganSheet) {
  try {
    console.log('Recalculating all saldos from zero...');
    
    const data = keuanganSheet.getDataRange().getValues();
    if (data.length <= 2) return; // No data to process
    
    let runningBalance = 0; // START FROM ZERO
    
    // Process each row starting from row 3 (after title and header)
    for (let i = 2; i < data.length; i++) {
      const row = data[i];
      const tipe = row[2]; // Column C
      const jumlah = row[3]; // Column D
      
      // Calculate new balance
      if (tipe === 'Masuk') {
        runningBalance += jumlah;
      } else {
        runningBalance -= jumlah;
      }
      
      // Update saldo in sheet (Column E)
      keuanganSheet.getRange(i + 1, 5).setValue(runningBalance);
    }
    
    console.log('Saldo recalculation completed from zero');
    
  } catch (error) {
    console.error('recalculateAllSaldos error:', error);
  }
}

// UTILITY: Function untuk hapus semua modal awal existing
function removeAllModalAwal() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const keuanganSheet = ss.getSheetByName('KEUANGAN');
    
    const data = keuanganSheet.getDataRange().getValues();
    const rowsToDelete = [];
    
    // Cari semua baris yang mengandung "modal awal" (case insensitive)
    data.forEach((row, index) => {
      if (row[1] && row[1].toString().toLowerCase().includes('modal awal')) {
        rowsToDelete.push(index + 1); // 1-based row number
      }
    });
    
    if (rowsToDelete.length === 0) {
      Browser.msgBox('Clean Modal', 'Tidak ada "Modal Awal" otomatis ditemukan.', Browser.Buttons.OK);
      return;
    }
    
    const confirm = Browser.msgBox('Remove Auto Modal', 
      `Ditemukan ${rowsToDelete.length} entry "Modal Awal" otomatis.\n\nApakah ingin menghapus semua modal awal otomatis?\n\nAnda bisa input modal sendiri sesuai kebutuhan.`, 
      Browser.Buttons.YES_NO);
    
    if (confirm !== 'yes') return;
    
    // Hapus dari bawah ke atas (supaya index tidak berubah)
    for (let i = rowsToDelete.length - 1; i >= 0; i--) {
      keuanganSheet.deleteRow(rowsToDelete[i]);
    }
    
    // Recalculate saldos setelah hapus modal
    recalculateAllSaldos(keuanganSheet);
    
    Browser.msgBox('Remove Complete', 
      `Berhasil menghapus ${rowsToDelete.length} entry "Modal Awal" otomatis.\n\nSystem sekarang mulai dari saldo 0.\n\nSilakan input modal Anda sendiri dengan tanggal yang tepat.`, 
      Browser.Buttons.OK);
    
  } catch (error) {
    Browser.msgBox('Error', 'Error removing modal: ' + error.toString(), Browser.Buttons.OK);
  }
}

// UTILITY: Function untuk verify saldo calculation
function verifySaldoCalculation() {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const keuanganSheet = ss.getSheetByName('KEUANGAN');
    
    const data = keuanganSheet.getDataRange().getValues();
    if (data.length <= 2) {
      Browser.msgBox('Verify Saldo', 'Belum ada data keuangan untuk diverifikasi.', Browser.Buttons.OK);
      return;
    }
    
    let calculatedBalance = 0;
    const issues = [];
    
    // Verify each row's saldo calculation
    data.slice(2).forEach((row, index) => {
      const rowNumber = index + 3; // Actual row number in sheet
      const tipe = row[2];
      const jumlah = row[3];
      const recordedSaldo = row[4];
      
      // Update calculated balance
      if (tipe === 'Masuk') {
        calculatedBalance += jumlah;
      } else {
        calculatedBalance -= jumlah;
      }
      
      // Check if recorded saldo matches calculated
      if (Math.abs(calculatedBalance - recordedSaldo) > 1) { // 1 rupiah tolerance
        issues.push(`Row ${rowNumber}: Calculated ${formatRupiah(calculatedBalance)}, Recorded ${formatRupiah(recordedSaldo)}`);
      }
    });
    
    if (issues.length === 0) {
      Browser.msgBox('Verify Saldo', 
        `✅ Semua saldo sudah akurat!\n\nSaldo akhir: ${formatRupiah(calculatedBalance)}\nTotal transaksi: ${data.length - 2}`, 
        Browser.Buttons.OK);
    } else {
      let message = `❌ Ditemukan ${issues.length} kesalahan saldo:\n\n`;
      issues.slice(0, 5).forEach(issue => {
        message += `• ${issue}\n`;
      });
      if (issues.length > 5) {
        message += `... dan ${issues.length - 5} lainnya\n`;
      }
      message += '\nGunakan "Recalculate All Saldos" untuk memperbaiki.';
      
      Browser.msgBox('Saldo Issues', message, Browser.Buttons.OK);
    }
    
  } catch (error) {
    Browser.msgBox('Error', 'Error verifying saldo: ' + error.toString(), Browser.Buttons.OK);
  }
}

