function getSmartTransactionDate(inputDate) {
  const today = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd');
  
  // Jika tidak ada input tanggal, gunakan timestamp sekarang
  if (!inputDate || inputDate.trim() === '') {
    return Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd HH:mm:ss');
  }
  
  // Jika tanggal = hari ini, gunakan timestamp sekarang (dengan jam real-time)
  if (inputDate === today) {
    return Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd HH:mm:ss');
  }
  
  // Jika tanggal ≠ hari ini (tanggal lain), gunakan 00:00:00
  return inputDate + ' 00:00:00';
}

function saveBarangMasukWithID(data) {
  try {
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    const sheet = ss.getSheetByName('BARANG_MASUK');
    const keuanganSheet = ss.getSheetByName('KEUANGAN');
    const produkSheet = ss.getSheetByName('MASTER_PRODUK');
    
    if (!sheet || !keuanganSheet || !produkSheet) {
      return { success: false, message: 'Required sheets not found' };
    }
    
    // Product ID logic
    const headers = produkSheet.getRange(2, 1, 1, produkSheet.getLastColumn()).getValues()[0];
    const hasProductID = headers.includes('Product_ID');
    
    let productCode = data.kodeProduk;
    let productID = null;
    
    if (hasProductID) {
      if (data.kodeProduk.startsWith('PID')) {
        productID = data.kodeProduk;
        const produkData = produkSheet.getDataRange().getValues().slice(3);
        const produkRow = produkData.find(row => row[0] === productID);
        if (produkRow) {
          productCode = produkRow[1];
        }
      } else {
        const produkData = produkSheet.getDataRange().getValues().slice(3);
        const produkRow = produkData.find(row => row[1] === data.kodeProduk);
        if (produkRow) {
          productID = produkRow[0];
          productCode = produkRow[1];
        }
      }
    }
    
    // SMART TIMESTAMP - gunakan helper function
    const transactionDate = getSmartTransactionDate(data.tanggal);
    console.log(`Transaction date: ${transactionDate} (input: ${data.tanggal})`);
    
    // Validasi tanggal
    const inputDate = new Date(transactionDate);
    const maxFutureDate = new Date();
    maxFutureDate.setDate(maxFutureDate.getDate() + 1);
    
    if (inputDate > maxFutureDate) {
      return { 
        success: false, 
        message: 'Tanggal tidak boleh lebih dari 1 hari ke depan dari hari ini' 
      };
    }
    
    const total = data.qty * data.harga;
    
