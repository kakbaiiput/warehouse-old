    const newRow = [transactionDate, data.noInvoice, data.supplier, referenceValue, data.qty, data.harga, total, 'Web User'];
    sheet.appendRow(newRow);
    
    const lastRow = sheet.getLastRow();
    simpleFormat('BARANG_MASUK', lastRow);
    
    // Auto-sort
    autoSortAfterTransaction('BARANG_MASUK');
    
    // Add to Keuangan
    const lastSaldo = getLastSaldo();
    const newSaldo = lastSaldo - total;
    const keuanganRow = [transactionDate, `Beli ${productCode} dari ${data.supplier}`, 'Keluar', total, newSaldo, data.noInvoice];
    keuanganSheet.appendRow(keuanganRow);
    
