// Handle OPTIONS requests for CORS preflight
function doOptions() {
  return HtmlService.createHtmlOutput()
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

// Handle GET requests (untuk test dan read data)
function doGet(e) {
  // Handle empty request
  if (!e || !e.parameter) {
    return createCORSResponse({
      success: true,
      message: 'Dimsum Inventory API is running with Product_ID system!',
      timestamp: new Date(),
      usage: 'Add ?action=test to test the API',
      availableActions: ['test', 'getMasterData', 'getDashboardData']
    });
  }
  
  const action = e.parameter.action || 'none';
  const callback = e.parameter.callback; // For JSONP
  const data = e.parameter.data; // For GET data submission
  
  // Debug logging
  console.log('doGet called with action:', action);
  
  try {
    let response;
    
    switch(action) {
      case 'getMasterData':
        response = getMasterDataWithID();
        break;
      case 'getDashboardData':
        response = getDashboardDataOptimized();
        break;
      case 'getFullMasukData':
        response = getFullMasukData();
        break;
      case 'getFullKeluarData':
        response = getFullKeluarData();
        break;
      case 'getAverageCosts':
        response = getAverageCostsOptimized();
        break;
      case 'saveBarangMasuk':
        if (data) {
          response = saveBarangMasukWithID(JSON.parse(decodeURIComponent(data)));
        } else {
          response = { success: false, message: 'No data provided for saveBarangMasuk' };
        }
        break;
      case 'saveBarangKeluar':
        if (data) {
          response = saveBarangKeluarWithID(JSON.parse(decodeURIComponent(data)));
        } else {
          response = { success: false, message: 'No data provided for saveBarangKeluar' };
        }
        break;
      case 'saveKeuangan':
        if (data) {
          response = saveKeuangan(JSON.parse(decodeURIComponent(data)));
        } else {
          response = { success: false, message: 'No data provided for saveKeuangan' };
        }
        break;
      case 'setupProductIDs':
        response = setupProductIDSystem();
        break;
      case 'test':
        response = { 
          success: true, 
          message: 'API Backend with Product_ID system is working!', 
          timestamp: new Date(),
          receivedAction: action
        };
        break;
      default:
        response = { 
          success: false, 
          message: 'Invalid action: ' + action,
          availableActions: ['test', 'getMasterData', 'getDashboardData', 'setupProductIDs', 'saveBarangMasuk', 'saveBarangKeluar', 'saveKeuangan']
        };
    }
    
    // Return JSONP if callback provided
    if (callback) {
      return ContentService
        .createTextOutput(`${callback}(${JSON.stringify(response)})`)
        .setMimeType(ContentService.MimeType.JAVASCRIPT);
    }
    
    return createCORSResponse(response);
    
  } catch (error) {
    console.error('doGet error:', error);
    const errorResponse = { 
      success: false, 
      message: 'Server Error: ' + error.toString(),
      action: action
    };
    
    if (callback) {
      return ContentService
        .createTextOutput(`${callback}(${JSON.stringify(errorResponse)})`)
        .setMimeType(ContentService.MimeType.JAVASCRIPT);
    }
    
    return createCORSResponse(errorResponse);
  }
}

// Handle POST requests
function doPost(e) {
  try {
    const postData = JSON.parse(e.postData.contents);
    const action = postData.action;
    
    let response;
    
    switch(action) {
      case 'saveBarangMasuk':
        response = saveBarangMasukWithID(postData.data);
        break;
      case 'saveBarangKeluar':
        response = saveBarangKeluarWithID(postData.data);
        break;
      case 'saveKeuangan':
        response = saveKeuangan(postData.data);
        break;
      case 'setupInitialData':
        response = setupInitialData();
        break;
      case 'setupProductIDs':
        response = setupProductIDSystem();
        break;
      default:
        response = { 
          success: false, 
          message: 'Invalid POST action: ' + action
        };
    }
    
    return createCORSResponse(response);
    
  } catch (error) {
    console.error('doPost error:', error);
    return createCORSResponse({ 
      success: false, 
      message: 'Server Error: ' + error.toString() 
    });
  }
}

// Create CORS-enabled response
function createCORSResponse(data) {
  return ContentService
    .createTextOutput(JSON.stringify(data))
    .setMimeType(ContentService.MimeType.JSON);
}

